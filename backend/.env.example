# Dhan API credentials
DHAN_CLIENT_ID=your_client_id_here
DHAN_ACCESS_TOKEN=your_access_token_here

# Candle duration in seconds (60 = 1min, 300 = 5min)
CANDLE_SECONDS=60

# Imbalance highlight ratio (e.g. 3 = 3x more buy vol than sell vol)
IMBALANCE_RATIO=3.0

# HFT flow classification (tuned on Render data 2026-03)
HFT_MFI_OVERBOUGHT=75
HFT_MFI_OVERSOLD=25
